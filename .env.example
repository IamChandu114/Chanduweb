# Analytics Configuration
# Add these to your .env.local file for local development
# For production, configure these in your Vercel project settings

# Vercel Analytics (required)
VITE_VERCEL_ANALYTICS_ID=

# Google Analytics 4 (optional)
VITE_GA4_ID=

# Microsoft Clarity (optional)
VITE_CLARITY_ID=

# Analytics Mode (true for production, false for development)
VITE_ENABLE_ANALYTICS=false
